rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write their own profile data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow users to access their own word_of_the_day subcollection
      match /word_of_the_day/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Allow users to access their own learned_words subcollection
      match /learned_words/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Allow users to access their own saved_words subcollection
      match /saved_words/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Allow users to read and write their own detection history
      match /detections/{detectionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Allow users to read and write their own learning progress
      match /progress/{progressId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Global word_of_the_day collection (allow authenticated users to read/write)
    match /word_of_the_day/{document} {
      allow read, write: if request.auth != null;
    }
    
    // Allow users to read shared vocabulary/object data (if any)
    match /vocabulary/{objectId} {
      allow read: if request.auth != null;
      // Only admins can write vocabulary data (add separate admin rules if needed)
    }
    
    // Detection results for authenticated users
    match /detection_results/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}